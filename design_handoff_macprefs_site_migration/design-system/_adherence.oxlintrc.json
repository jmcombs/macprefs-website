{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/code/**",
              "components/core/**",
              "components/paper/**",
              "ui_kits/paper-landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|Manrope|Instrument Serif))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, Manrope, Instrument Serif."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|dot|size|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, dot, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|accent|iconLeft|iconRight|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, accent, iconLeft, iconRight, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|headerRight|accentRail|accent|padding|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, headerRight, accentRail, accent, padding, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tok'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|italic|bold|children|key|ref|className|style|children)$/]",
        "message": "<Tok> doesn't accept that prop. Declared props: kind, italic, bold, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|commands|copyable|prompt|children|key|ref|className|style|children)$/]",
        "message": "<CommandBox> doesn't accept that prop. Declared props: title, commands, copyable, prompt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactFormData'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|email|message|key|ref|className|style|children)$/]",
        "message": "<ContactFormData> doesn't accept that prop. Declared props: name, email, message."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|accent|title|linkText|linkHref|align|children|key|ref|className|style|children)$/]",
        "message": "<FeatureItem> doesn't accept that prop. Declared props: icon, accent, title, linkText, linkHref, align, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureItem'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<FeatureItem> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaperButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|accent|round|uppercase|iconLeft|iconRight|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<PaperButton> doesn't accept that prop. Declared props: variant, size, accent, round, uppercase, iconLeft, iconRight, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaperCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tint|media|raised|interactive|align|padding|children|key|ref|className|style|children)$/]",
        "message": "<PaperCard> doesn't accept that prop. Declared props: tint, media, raised, interactive, align, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaperCard'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<PaperCard> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Swatch'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|name|hex|size|shape|copyable|key|ref|className|style|children)$/]",
        "message": "<Swatch> doesn't accept that prop. Declared props: color, name, hex, size, shape, copyable."
      },
      {
        "selector": "JSXOpeningElement[name.name='TeamSocial'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|href|key|ref|className|style|children)$/]",
        "message": "<TeamSocial> doesn't accept that prop. Declared props: icon, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
