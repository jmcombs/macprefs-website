{
  "name": "@macprefs/design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Netservant Design System — tokens + React (raw .jsx) components, vendored for macprefs.",
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": "./src/index.js",
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "src",
    "components",
    "tokens",
    "styles.css",
    "assets",
    "_ds_manifest.json"
  ],
  "scripts": {
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
